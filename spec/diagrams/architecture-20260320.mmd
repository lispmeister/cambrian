%%{init: {'flowchart': {'htmlLabels': false}} }%%
graph TB
    subgraph Host["Host Machine"]
        direction TB

        subgraph M2["M2 Orchestration (host-side)"]
            RunM2["scripts/run_m2.py\nBO driver"]
            BOLoop["bo_loop.py\ncandidate selection\nbo-observations.jsonl"]
            Campaign["campaign.py\nrun_campaign()\npoll /versions?campaign-id="]
            PrimeRunner["prime_runner.py\ngenerate artifact from\nCAMBRIAN-SPEC-005.md"]
            RunM2 --> BOLoop --> Campaign --> PrimeRunner
        end

        Supervisor["Supervisor :8400\n/spawn /versions /promote /rollback\ngeneration ledger + lifecycle"]

        subgraph LabContainer["Test Rig Container (ephemeral)"]
            direction TB
            TestRig["test_rig.py\nmanifest -> build -> test\n-> start -> health -> report\nNo LLM. No API key."]
        end

        subgraph Artifacts["Artifacts Repo (sibling)"]
            direction TB
            GenStore["generations.json\nglobal generation history"]
            CampaignDirs["campaigns/<campaign-id>/gen-N\nartifact dirs + manifest"]
            GenStore --- CampaignDirs
        end
    end

    Spec["Genome Spec\nspec/CAMBRIAN-SPEC-005.md"]
    LLM["LLM API\n(Anthropic / other)"]

    PrimeRunner -->|"reads"| Spec
    PrimeRunner -->|"prompt + context"| LLM
    LLM -->|"files"| PrimeRunner
    PrimeRunner -->|"writes artifact"| CampaignDirs

    Campaign -->|"POST /spawn {generation, artifact-path, spec-hash, campaign-id}"| Supervisor
    Supervisor -->|"create lab-gen-N"| LabContainer
    Supervisor -->|"bind /workspace + isolated /output"| LabContainer
    LabContainer -->|"viability-report.json in /output"| Supervisor
    Supervisor -->|"update tested record"| GenStore

    Campaign -->|"GET /versions?campaign-id=..."| Supervisor
    Campaign -->|"POST /promote or /rollback"| Supervisor
    Supervisor -->|"terminal outcome"| GenStore

    NoteSec["Container guards\nNetworkMode=none\nSecurityOpt=no-new-privileges\nCapDrop=ALL"]
    Supervisor -. "enforces" .-> NoteSec

    style Host fill:#f8f9fa,stroke:#333,stroke-width:2px
    style M2 fill:#e8f4fd,stroke:#1e88e5,stroke-width:2px
    style Supervisor fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style LabContainer fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,stroke-dasharray: 5 5
    style Artifacts fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style LLM fill:#ede7f6,stroke:#5e35b1,stroke-width:1px
    style Spec fill:#e3f2fd,stroke:#1565c0,stroke-width:1px
    style NoteSec fill:#fffde7,stroke:#f9a825,stroke-width:1px
