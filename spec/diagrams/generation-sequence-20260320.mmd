sequenceDiagram
    actor Operator
    participant RunM2 as scripts/run_m2.py
    participant BO as bo_loop.py
    participant Campaign as campaign.py
    participant PrimeRunner as prime_runner.py
    participant LLM as LLM API
    participant Supervisor as Supervisor :8400
    participant Lab as Test Rig container

    rect rgb(234, 242, 248)
        Note over RunM2,Supervisor: Stage 1 setup
        RunM2->>BO: initialize with CAMBRIAN-SPEC-005.md
        BO->>Supervisor: GET /versions
        Supervisor-->>BO: current generations
        Note right of BO: detect start generation and reload bo-observations.jsonl
    end

    loop BO iteration (budgeted)
        rect rgb(244, 236, 247)
            Note over BO,LLM: Generate candidate artifact(s)
            BO->>Campaign: run_campaign(spec variant, n, start_generation)
            Campaign->>PrimeRunner: generate_artifact(...)
            PrimeRunner->>LLM: system prompt (from spec) + user prompt
            LLM-->>PrimeRunner: complete file set
            PrimeRunner-->>Campaign: artifact path + manifest metadata
        end

        rect rgb(234, 250, 241)
            Note over Campaign,Lab: Mechanical verification
            Campaign->>Supervisor: POST /spawn {generation, artifact-path, spec-hash, campaign-id}
            Supervisor->>Lab: create lab-gen-N with /workspace + isolated /output
            Note right of Lab: NetworkMode=none, no ANTHROPIC_API_KEY, no-new-privileges + CapDrop=ALL
            Lab->>Lab: manifest -> build -> test -> start -> health
            Lab-->>Supervisor: /output/viability-report.json
            Supervisor-->>Campaign: generation record becomes tested
            Campaign->>Supervisor: GET /versions?campaign-id=... (poll)
        end

        alt generation viable
            Campaign->>Supervisor: POST /promote {generation}
            Note right of Supervisor: mark promoted and trigger baseline reverse-run in background
        else generation non-viable
            Campaign->>Supervisor: POST /rollback {generation}
            Note right of Supervisor: mark failed
        end

        Campaign-->>BO: campaign summary (viability_rate + fitness means)
        BO->>BO: persist observation to bo-observations.jsonl
    end

    rect rgb(254, 249, 231)
        Note over RunM2,BO: Completion
        BO-->>RunM2: best spec + metrics
        RunM2->>RunM2: write best-spec.md + best-spec-meta.json
    end
